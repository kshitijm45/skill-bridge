# Copy this file to backend/.env and fill in your values
# Never commit .env to version control

# Required: Google Gemini API key
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Clerk publishable key — enables JWT auth
# Without this, all requests run as dev_user (fine for local testing)
# Create a free app at https://clerk.com → API Keys
# CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Optional: override the SQLite database file path (default: skill_bridge.db)
# DB_PATH=skill_bridge.db
