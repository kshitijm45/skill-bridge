# Copy this file to frontend/.env and fill in your values
# Vite only exposes variables prefixed with VITE_ to the browser bundle

# Optional: Clerk publishable key — enables sign-in UI
# Without this, the app runs without auth (no sign-in page shown)
# Must match CLERK_PUBLISHABLE_KEY in backend/.env
# Create a free app at https://clerk.com → API Keys
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
